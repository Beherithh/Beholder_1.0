import asyncio
from database.core import get_session
from database.models import AppSettings

async def reset():
    async with get_session() as s:
        obj = await s.get(AppSettings, 'binance_tg_last_message_id')
        print(f'Current value: {obj.value if obj else "Not set"}')
        
        if obj:
            await s.delete(obj)
            await s.commit()
            print('Successfully reset!')
        else:
            print('Nothing to reset')

asyncio.run(reset())
